#Algoritimo que Define Números iguais e diferentes e mostra a diferença entre os números
a=int(input("Digite o primeiro número: "))
b=int(input("Digite o segundo número: "))

if a==b:
    print("Numeros Iguais")
else:
    print("Numeros Diferentes")
    if a>0 and b>0:
        print("O resultado da diferença dos dois números foram:",a-b)
    elif b<0:
        print("O resultado da diferença dos dois números foram:",a+b)
    else:
        print("O resultado da diferença dos dois números foram:",a-(-b))
