#Algoritmo para descobrir se número é par ou impar e positivo e negativo
a=int(input("Digite um número: "))

if a>0:
    if a%2==0:
        print("Par e positivo")
    else:
        print("Impar e positivo")
else:
    if a%2==0:
        print("Par e negativo")
    else:
        print("Impar e negativo")
