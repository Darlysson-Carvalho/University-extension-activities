#Algoritmo de soma de dois números e verifica o maior
a=int(input("Digite um número: "))
b=int(input("Digite outro número: "))
c=a+b

if a==b:
    print("Os dois números são iguais .A soma dos dois resultou em:" ,c )
else:
    if a>b:
        print("O maior número foi",a)
        print("A soma dos dois resultou em",c )
    else:
        print("O maior número foi",b)
        print("A soma dos dois resultou em:",c )
